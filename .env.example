# Core
DJANGO_PRODUCTION=1
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-secure-key
DJANGO_ALLOWED_HOSTS=aguasyservicioslaz.cl,www.aguasyservicioslaz.cl
DJANGO_CSRF_TRUSTED_ORIGINS=https://aguasyservicioslaz.cl,https://www.aguasyservicioslaz.cl
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=0

# Database
USE_REMOTE_DB=1
DB_NAME=aguasyse_ays_database
DB_USER=aguasyse_admin
DB_PASSWORD=replace-with-db-password
DB_HOST=s480.v2nets.com
DB_PORT=3306
DB_CONN_MAX_AGE=60

# Static and media (cPanel example)
DJANGO_STATIC_ROOT=/home/aguasyse/public_html/static/
DJANGO_MEDIA_ROOT=/home/aguasyse/public_html/media/
STATIC_CACHE_SECONDS=604800

